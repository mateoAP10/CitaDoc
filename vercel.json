{
  "rewrites": [
    {
      "source": "/demo/:slug",
      "destination": "/demo.html?slug=:slug"
    },
    {
      "source": "/generar",
      "destination": "/landing.html"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": ".+\\.citadoc\\.lat"
        }
      ],
      "destination": "/citadoc-web.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
